# =========================
# 33income (Windows runtime)
# =========================

# Logging (개발 기본값: DEBUG)
INCOME33_LOG_LEVEL=DEBUG
INCOME33_LOG_DIR=logs

# Common network timeout
INCOME33_HTTP_TIMEOUT_SECONDS=10

# Control tower web (관제 PC)
INCOME33_CONTROL_TOWER_HOST=127.0.0.1
INCOME33_CONTROL_TOWER_PORT=8330
INCOME33_DB_PATH=data/33income.db
INCOME33_MOCK_AGENT_COUNT=18
INCOME33_STALE_SECONDS=180

# Agent (봇 PC)
# 사용자 친화 별칭 (docs에서 그대로 사용)
CONTROL_TOWER_URL=http://127.0.0.1:8330

# 내부 키
INCOME33_AGENT_CONTROL_TOWER_URL=http://127.0.0.1:8330
INCOME33_AGENT_PC_ID=pc-01
INCOME33_AGENT_HOSTNAME=WIN-PC-01
INCOME33_AGENT_IP_ADDRESS=192.168.10.101
INCOME33_AGENT_BOT_ID=sender-01
INCOME33_AGENT_BOT_TYPE=sender
INCOME33_AGENT_HEARTBEAT_INTERVAL_SECONDS=30

# NewTA login/session control (bot PC)
INCOME33_LOGIN_URL=https://newta.3o3.co.kr/login?r=%2F
INCOME33_LOGIN_ID=
INCOME33_LOGIN_PASSWORD=
INCOME33_DASHBOARD_URL=https://newta.3o3.co.kr/dashboard

# Optional selector overrides. Leave blank to use built-in defaults.
INCOME33_LOGIN_ID_SELECTOR=
INCOME33_LOGIN_PASSWORD_SELECTOR=
INCOME33_LOGIN_SUBMIT_SELECTOR=
INCOME33_LOGIN_AUTH_CODE_SELECTOR=
INCOME33_LOGIN_AUTH_SUBMIT_SELECTOR=

INCOME33_PROFILE_ROOT=profiles
INCOME33_BROWSER_EXE=
INCOME33_BROWSER_DEBUG_PORT_BASE=29200

# Browser control dry-run (server/tests 권장)
INCOME33_BROWSER_CONTROL_DRY_RUN=0
# Backward-compatible aliases
INCOME33_LOGIN_DRY_RUN=0
INCOME33_LOGIN_BROWSER_DRY_RUN=0

# Session keepalive
INCOME33_REFRESH_URL=https://newta.3o3.co.kr/tasks/git
INCOME33_REFRESH_INTERVAL_SECONDS=600
INCOME33_REFRESH_ENABLED=0

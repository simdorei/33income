# ============================================================
# 33income .env example
# ============================================================
# 사용법:
# 1) setup_windows.bat 실행 시 이 파일이 C:\33income\.env 로 복사됩니다.
# 2) 실제 수정은 .env 에서만 하세요. .env.example 은 예시 파일입니다.
# 3) 실제 ID/PW/인증정보는 Git에 올리지 마세요.
# 4) 운영에서 보통 쓰는 실행 파일은 두 개입니다.
#    - 관제 PC: run_control_tower.bat
#    - 봇 PC:   run_agent.bat
#    - run_sender.bat / run_reporter.bat 은 단독 디버그용입니다.
#
# 빠른 판단:
# - 한 PC에서만 테스트: 아래 값을 거의 그대로 써도 됩니다.
# - 여러 PC 운영: 관제 PC는 HOST=0.0.0.0, 봇 PC는 CONTROL_TOWER_URL을 관제 PC IP로 바꾸세요.
# ============================================================


# ============================================================
# A. 모든 PC 공통
# ============================================================
INCOME33_LOG_LEVEL=DEBUG
INCOME33_LOG_DIR=logs
INCOME33_HTTP_TIMEOUT_SECONDS=10


# ============================================================
# B. 관제 PC 설정 - run_control_tower.bat 실행하는 PC
# ============================================================
# 중요:
# - 127.0.0.1 은 이 PC 자기 자신만 접속 가능하다는 뜻입니다.
# - 다른 봇 PC들이 붙어야 하면 반드시 0.0.0.0 으로 여세요.
# - 같은 사무실/LAN에서 접속하려면 Windows 방화벽 TCP 8330도 허용해야 합니다.
#
# 단일 PC 테스트라면 127.0.0.1 가능:
# INCOME33_CONTROL_TOWER_HOST=127.0.0.1
#
# 여러 PC 운영이면 아래처럼 사용:
INCOME33_CONTROL_TOWER_HOST=0.0.0.0
INCOME33_CONTROL_TOWER_PORT=8330
INCOME33_DB_PATH=data/33income.db

# 대시보드에 미리 보일 고정 슬롯 수. 현재 18봇 기준.
INCOME33_BOOTSTRAP_AGENT_COUNT=18

# 이 시간 동안 heartbeat가 없으면 오래된 상태로 판단하는 기준 초.
INCOME33_STALE_SECONDS=180


# ============================================================
# C. 봇/에이전트 PC 설정 - run_agent.bat 실행하는 각 PC
# ============================================================
# 중요:
# - 봇 PC에서는 127.0.0.1 쓰면 안 됩니다. 그건 봇 PC 자기 자신입니다.
# - 아래 192.168.0.23 을 관제 PC의 실제 LAN IP로 바꾸세요.
# - 관제 PC IP 확인 명령: ipconfig
# - 연결 확인: run_agent.bat 창에 CONNECTED ... 가 떠야 합니다.
#
# 예시:
# CONTROL_TOWER_URL=http://192.168.0.23:8330
# INCOME33_AGENT_CONTROL_TOWER_URL=http://192.168.0.23:8330
CONTROL_TOWER_URL=http://192.168.0.23:8330
INCOME33_AGENT_CONTROL_TOWER_URL=http://192.168.0.23:8330

# 각 PC마다 고유하게 바꾸세요.
# pc-01 ~ pc-09  : sender-01 ~ sender-09
# pc-10 ~ pc-18  : reporter-01 ~ reporter-09
INCOME33_AGENT_PC_ID=pc-01
INCOME33_AGENT_HOSTNAME=BOT-PC-01

# 이 봇 PC 자신의 LAN IP입니다. 표시/기록용입니다.
INCOME33_AGENT_IP_ADDRESS=192.168.0.101

# 이 PC가 담당할 봇 ID/type입니다.
INCOME33_AGENT_BOT_ID=sender-01
INCOME33_AGENT_BOT_TYPE=sender

# 관제에 상태를 보내는 주기 초. 로그인/인증 상태 추적을 위해 5초 권장.
INCOME33_AGENT_HEARTBEAT_INTERVAL_SECONDS=5


# ============================================================
# D. NewTA 로그인/브라우저 제어 - 봇 PC에서 사용
# ============================================================
INCOME33_LOGIN_URL=https://newta.3o3.co.kr/login?r=%2F

# 실제 계정 정보는 각 봇 PC의 .env에만 입력하세요. Git에 올리지 마세요.
INCOME33_LOGIN_ID=
INCOME33_LOGIN_PASSWORD=

# 브라우저 자동제어 실사용이면 0, 명령만 테스트하는 dry-run이면 1.
INCOME33_BROWSER_CONTROL_DRY_RUN=0
INCOME33_LOGIN_DRY_RUN=0
INCOME33_LOGIN_BROWSER_DRY_RUN=0

# Chrome/Edge 실행파일 자동탐색이 실패할 때만 직접 경로를 넣으세요.
# 예: C:\Program Files\Google\Chrome\Application\chrome.exe
INCOME33_BROWSER_EXE=

# PC별 Chrome debug port 시작값. 보통 그대로 둡니다.
INCOME33_BROWSER_DEBUG_PORT_BASE=29200

# 브라우저 프로필 저장 위치. PC별 로그인 세션 보존용입니다.
INCOME33_PROFILE_ROOT=profiles


# ============================================================
# E. NewTA 세션 유지 새로고침
# ============================================================
INCOME33_REFRESH_URL=https://newta.3o3.co.kr/tasks/git
INCOME33_REFRESH_INTERVAL_SECONDS=600

# 운영 봇 PC에서는 1 권장. 처음 연결 테스트 중이면 0으로 둬도 됩니다.
INCOME33_REFRESH_ENABLED=0


# ============================================================
# F. NewTA 발송 목록조회 request 테스트
# ============================================================
# 로그인된 브라우저 세션으로 officeId를 자동 조회한 뒤 이 연도/페이지 크기로 목록만 조회합니다.
# 관제 버튼 '목록조회 테스트'는 발송하지 않고 taxDocId 개수/페이지 수만 확인합니다.
INCOME33_TAX_API_BASE_URL=https://ta-gw.3o3.co.kr
INCOME33_TAXDOC_YEAR=2025
INCOME33_TAXDOC_PAGE_SIZE=20


# ============================================================
# G. 고급 설정 - 셀렉터 override, 보통 비워두세요
# ============================================================
# 사이트 HTML이 바뀌어 기본 선택자가 안 맞을 때만 입력합니다.
# 빈 값이면 코드 내장 기본값을 사용합니다. XPath는 xpath=//input[...] 형식으로 넣습니다.
# 정확한 selector/xpath를 넣으면 기본 후보를 하나씩 찾는 시간을 줄일 수 있습니다.
INCOME33_SELECTOR_TIMEOUT_MS=2000
INCOME33_LOGIN_ID_SELECTOR=
INCOME33_LOGIN_PASSWORD_SELECTOR=
INCOME33_LOGIN_SUBMIT_SELECTOR=
INCOME33_LOGIN_AUTH_CODE_SELECTOR=
INCOME33_LOGIN_AUTH_SUBMIT_SELECTOR=
